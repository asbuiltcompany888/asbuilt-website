---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="As-Built Company — 3D Scanning & As-Built Documentation">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">3D Scanning · As-Built Documentation</div>
      <h1>Precision data. <span class="accent">Smarter builds.</span></h1>
      <p class="lead">
        We capture buildings, sites, and interiors with survey-grade 3D laser scanning and deliver the drawings, models,
        and 360&deg; walkthroughs your project actually needs.
      </p>
      <div class="actions">
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
        <a href="/services/" class="btn btn-outline-light">Explore Services</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title-centered">
        <span class="eyebrow">What We Do</span>
        <h2>Capture. Document. Visualize.</h2>
        <p>End-to-end as-built services for architects, contractors, and property owners.</p>
      </div>
      <div class="grid grid-3">
        <div class="icon-card">
          <div class="icon">◧</div>
          <h3>3D Laser Scanning</h3>
          <p>High-density point clouds captured with Leica BLK2GO and other survey-grade equipment.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
        <div class="icon-card">
          <div class="icon">▤</div>
          <h3>As-Built Drawings</h3>
          <p>Floor plans, elevations, and sections drawn to the conditions actually on site &mdash; not design intent.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
        <div class="icon-card">
          <div class="icon">◉</div>
          <h3>Virtual Tours</h3>
          <p>Interactive 360&deg; walkthroughs from Insta360 captures &mdash; share a site without leaving your desk.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
        <div class="icon-card">
          <div class="icon">▦</div>
          <h3>BIM &amp; 3D Modeling</h3>
          <p>Revit and Rhino models built from scan data, ready for coordination or design development.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
        <div class="icon-card">
          <div class="icon">⊞</div>
          <h3>Construction Documentation</h3>
          <p>Recurring site capture for milestone documentation and remote stakeholder updates.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
        <div class="icon-card">
          <div class="icon">⌂</div>
          <h3>Real Estate Floor Plans</h3>
          <p>Fast, dimensioned floor plans for listings, lease drawings, and property records.</p>
          <a href="/services/" class="link-arrow">Learn more <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="section-title-centered">
        <span class="eyebrow">Why As-Built Company</span>
        <h2>Built for accuracy. Designed for speed.</h2>
      </div>
      <div class="grid grid-3">
        <div class="icon-card">
          <div class="icon">⚡</div>
          <h3>Fast turnaround</h3>
          <p>Site capture in hours, deliverables in days &mdash; not weeks. We move at the pace of your project.</p>
        </div>
        <div class="icon-card">
          <div class="icon">◎</div>
          <h3>Survey-grade accuracy</h3>
          <p>Millimeter-precision point clouds you can build from with confidence.</p>
        </div>
        <div class="icon-card">
          <div class="icon">⚙</div>
          <h3>Every deliverable, one team</h3>
          <p>From raw scans to finished drawings and tours &mdash; no handoffs between vendors.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Recent Projects</div>
          <h2>See our work</h2>
        </div>
        <a href="/projects/" class="link-arrow">View all projects <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div class="card-image"><span class="card-badge">Commercial</span>(project image)</div>
          <div class="card-body">
            <h3>500,000 SF commercial retrofit</h3>
            <p>Full as-built capture and Revit model for a multi-floor office renovation in downtown LA.</p>
          </div>
          <div class="card-footer">
            <span>Los Angeles, CA</span>
            <a href="/projects/" class="arrow-link">Read more →</a>
          </div>
        </div>
        <div class="card">
          <div class="card-image"><span class="card-badge">Residential</span>(project image)</div>
          <div class="card-body">
            <h3>Historic home documentation</h3>
            <p>Point cloud and floor plans of a 1920s craftsman for a sensitive renovation.</p>
          </div>
          <div class="card-footer">
            <span>Pasadena, CA</span>
            <a href="/projects/" class="arrow-link">Read more →</a>
          </div>
        </div>
        <div class="card">
          <div class="card-image"><span class="card-badge">Industrial</span>(project image)</div>
          <div class="card-body">
            <h3>Manufacturing facility scan</h3>
            <p>Floor-to-ceiling capture of an active plant with virtual tour for remote teams.</p>
          </div>
          <div class="card-footer">
            <span>Inland Empire, CA</span>
            <a href="/projects/" class="arrow-link">Read more →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Ready to scan?</h3>
          <p>Tell us about your project. We respond within one business day.</p>
        </div>
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
