---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Resources — As-Built Company">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Resources</div>
      <h1>Knowledge. Tools. <span class="accent">Better Projects.</span></h1>
      <p class="lead">Explore our guides, articles, and tools to help you make informed decisions and get the most out of AI, robotics, and precision measurements.</p>
      <div class="hero-search">
        <span class="search-icon">⌕</span>
        <input type="search" placeholder="Search resources..." aria-label="Search resources" />
      </div>
      <div class="tabs">
        <a href="#" class="tab active"><span class="tab-icon">⊞</span> All Resources</a>
        <a href="#" class="tab"><span class="tab-icon">📖</span> Guides</a>
        <a href="#" class="tab"><span class="tab-icon">▤</span> Articles</a>
        <a href="#" class="tab"><span class="tab-icon">◧</span> Case Studies</a>
        <a href="#" class="tab"><span class="tab-icon">⚙</span> Tools &amp; Templates</a>
        <a href="#" class="tab"><span class="tab-icon">▶</span> Videos</a>
        <a href="#" class="tab"><span class="tab-icon">?</span> FAQs</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Featured Resources</div>
        </div>
        <a href="#" class="link-arrow">View All Resources <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-4">
        <div class="card">
          <div class="card-image"><span class="card-badge">Guide</span></div>
          <div class="card-body">
            <h3>The Ultimate Guide to As-Built Drawings</h3>
            <p>Everything you need to know about as-built documentation and why accuracy matters.</p>
          </div>
          <div class="card-footer">
            <span>8 min read</span>
            <a href="#" class="arrow-link">→</a>
          </div>
        </div>
        <div class="card">
          <div class="card-image"><span class="card-badge">Article</span></div>
          <div class="card-body">
            <h3>2D vs 3D As-Built Drawings: Which Do You Need?</h3>
            <p>Compare 2D and 3D deliverables to determine the best fit for your project scope and budget.</p>
          </div>
          <div class="card-footer">
            <span>5 min read</span>
            <a href="#" class="arrow-link">→</a>
          </div>
        </div>
        <div class="card">
          <div class="card-image"><span class="card-badge">Case Study</span></div>
          <div class="card-body">
            <h3>How We Delivered 3D As-Builts for a 500,000 Sq. Ft. Facility</h3>
            <p>A case study on speed, accuracy, and collaboration using AI and robotics.</p>
          </div>
          <div class="card-footer">
            <span>6 min read</span>
            <a href="#" class="arrow-link">→</a>
          </div>
        </div>
        <div class="card">
          <div class="card-image"><span class="card-badge">Template</span></div>
          <div class="card-body">
            <h3>As-Built Drawing Request Checklist</h3>
            <p>Use this checklist to ensure you provide all the necessary information for an accurate quote.</p>
          </div>
          <div class="card-footer">
            <span>↓ Download</span>
            <a href="#" class="arrow-link">→</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="tools-strip">
        <div class="intro">
          <div class="eyebrow">Tools &amp; Calculators</div>
          <h3>Helpful Tools for Smarter Planning</h3>
          <p>Use our free tools and calculators to estimate, measure, and plan your projects with confidence.</p>
          <a href="#" class="btn btn-secondary">Explore All Tools <span class="arrow">→</span></a>
        </div>
        <div class="tools-grid">
          <div class="tool">
            <div class="icon">▦</div>
            <h4>Square Footage Calculator</h4>
            <p>Quickly calculate gross building area from dimensions.</p>
            <a href="#" class="link-arrow">Use Tool <span class="arrow">→</span></a>
          </div>
          <div class="tool">
            <div class="icon">⊞</div>
            <h4>File Format Guide</h4>
            <p>Learn about the file formats we accept and deliver.</p>
            <a href="#" class="link-arrow">View Guide <span class="arrow">→</span></a>
          </div>
          <div class="tool">
            <div class="icon">⏤</div>
            <h4>Accuracy Guide</h4>
            <p>Understand accuracy levels and how they impact your project.</p>
            <a href="#" class="link-arrow">View Guide <span class="arrow">→</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Video Resources</div>
        </div>
        <a href="#" class="link-arrow">View All Videos <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-4">
        <div class="card video-card">
          <div class="card-image">
            <div class="play-btn">▶</div>
            <div class="duration">2:45</div>
          </div>
          <div class="card-body">
            <h3>How 3D Laser Scanning Works</h3>
            <p>See how we capture millions of points with millimeter accuracy.</p>
          </div>
        </div>
        <div class="card video-card">
          <div class="card-image">
            <div class="play-btn">▶</div>
            <div class="duration">3:12</div>
          </div>
          <div class="card-body">
            <h3>From Scan to As-Built</h3>
            <p>Our end-to-end process from data capture to final deliverables.</p>
          </div>
        </div>
        <div class="card video-card">
          <div class="card-image">
            <div class="play-btn">▶</div>
            <div class="duration">2:28</div>
          </div>
          <div class="card-body">
            <h3>Benefits of Accurate As-Builts</h3>
            <p>How accurate documentation saves time, money, and reduces risk.</p>
          </div>
        </div>
        <div class="card video-card">
          <div class="card-image">
            <div class="play-btn">▶</div>
            <div class="duration">2:05</div>
          </div>
          <div class="card-body">
            <h3>AI-Powered Data Processing</h3>
            <p>How AI and automation deliver faster, cleaner, and smarter results.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Can&rsquo;t find what you&rsquo;re looking for?</h3>
          <p>Our team is here to help. Contact us for personalized recommendations and expert advice.</p>
        </div>
        <a href="/contact/" class="btn btn-secondary">Contact Us <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
