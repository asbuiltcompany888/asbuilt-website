---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Pricing — As-Built Company">
  <section class="hero hero-compact">
    <div class="container">
      <div class="eyebrow">Pricing</div>
      <h1>Transparent pricing for <span class="accent">every project.</span></h1>
      <p class="lead">Most projects are custom-scoped. These packages cover the most common requests &mdash; everything else is quoted on a per-project basis.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Floor Plan Only</h3>
          <p style="color: var(--color-muted); margin-bottom: 0;">Best for real estate and quick documentation</p>
          <div class="price">From $499</div>
          <div class="price-meta">per residential property</div>
          <ul>
            <li>Single-day site capture</li>
            <li>Dimensioned 2D floor plan (PDF)</li>
            <li>Standard turnaround in 48 hours</li>
            <li>Up to 3,000 SF included</li>
          </ul>
          <a href="/contact/" class="btn">Request Quote <span class="arrow">→</span></a>
        </div>

        <div class="pricing-card featured">
          <div class="tier-badge">Most Popular</div>
          <h3>As-Built Package</h3>
          <p style="color: var(--color-muted); margin-bottom: 0;">Full documentation for renovations</p>
          <div class="price">From $2,500</div>
          <div class="price-meta">per project</div>
          <ul>
            <li>Survey-grade 3D laser scan</li>
            <li>2D as-built drawings (AutoCAD)</li>
            <li>Registered E57 point cloud</li>
            <li>360&deg; virtual tour included</li>
            <li>5-business-day turnaround</li>
          </ul>
          <a href="/contact/" class="btn">Request Quote <span class="arrow">→</span></a>
        </div>

        <div class="pricing-card">
          <h3>BIM &amp; Full Modeling</h3>
          <p style="color: var(--color-muted); margin-bottom: 0;">For coordination and design work</p>
          <div class="price">Custom</div>
          <div class="price-meta">quoted per scope</div>
          <ul>
            <li>Everything in As-Built Package</li>
            <li>LOD 200&ndash;400 Revit model</li>
            <li>MEP/structural coordination</li>
            <li>Clash detection reports</li>
            <li>Project-specific deliverables</li>
          </ul>
          <a href="/contact/" class="btn">Request Quote <span class="arrow">→</span></a>
        </div>
      </div>

      <div class="section-title-centered" style="margin-top: 4rem;">
        <p style="color: var(--color-muted);">Need something different? Most projects are custom &mdash; tell us the goal and we&rsquo;ll scope the right package.</p>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="section-title-centered">
        <span class="eyebrow">FAQ</span>
        <h2>Pricing questions</h2>
      </div>
      <div class="prose">
        <h3>Do you offer fixed-price quotes?</h3>
        <p>Yes &mdash; once we understand the scope, square footage, and deliverable format, we provide a fixed-price quote that doesn&rsquo;t change unless the scope does.</p>

        <h3>What factors affect the price?</h3>
        <p>Site complexity, square footage, level of detail required, deliverable format (CAD vs. Revit vs. point cloud), and timeline. We&rsquo;ll walk you through the variables when you reach out.</p>

        <h3>Do you charge for site visits or estimates?</h3>
        <p>No. Initial consultations, estimates, and quotes are free.</p>

        <h3>Do you require a deposit?</h3>
        <p>For projects over $1,500, we typically require a 50% deposit to schedule the scan, with the balance due on delivery.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Ready to get a quote?</h3>
          <p>Send us a few details about your project and we&rsquo;ll respond within one business day.</p>
        </div>
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
