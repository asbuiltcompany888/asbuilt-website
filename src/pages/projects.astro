---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Projects — As-Built Company"
  description="Recent residential, commercial, and industrial as-built documentation projects across California."
>
  <section class="hero hero-compact">
    <div class="container">
      <div class="eyebrow">Projects</div>
      <h1>Recent <span class="accent">work.</span></h1>
      <p class="lead">A selection of residential, commercial, and industrial as-built projects completed across California. Client names and addresses removed for privacy &mdash; city labels and project scope shown.</p>
    </div>
  </section>

  <!-- COMMERCIAL -->
  <section>
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Commercial</div>
          <h2>Restaurants, retail, multi-tenant, civic</h2>
        </div>
        <a href="/services/" class="link-arrow">View commercial services <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div class="card-image"><span class="card-badge">Commercial</span>(multi-suite floor plan)</div>
          <div class="card-body">
            <h3>Multi-Suite Commercial Complex</h3>
            <p>Existing-conditions first-floor as-built for a 5-suite commercial complex totaling roughly <strong>29,000 SF</strong> (suites of 10,486 / 8,834 / 4,390 / 3,197 / 2,454 SF). Delivered as a single coordinated CAD set for the owner&rsquo;s leasing and TI workflow.</p>
          </div>
          <div class="card-footer">
            <span>Stockton, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Commercial · Civic</span>(campus civil)</div>
          <div class="card-body">
            <h3>Community College Campus Civil As-Builts</h3>
            <p>DSA-submittal as-built drawings for <strong>domestic water, fire water, and sewer infrastructure</strong> improvements at a Los Angeles community college campus. Coordinated civil deliverables for state agency approval.</p>
          </div>
          <div class="card-footer">
            <span>Los Angeles, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Commercial</span>(restaurant TI)</div>
          <div class="card-body">
            <h3>Restaurant Tenant Improvement</h3>
            <p>1,863 SF existing-conditions floor plan with proposed kitchen + retail seating layout. Full equipment plan including walk-in refrigerator, freezer, hood, gas stove, and prep barricade. Delivered CAD-ready for permitting.</p>
          </div>
          <div class="card-footer">
            <span>Seal Beach, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RESIDENTIAL -->
  <section class="section-surface">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Residential</div>
          <h2>Coastal homes, estates, duplexes</h2>
        </div>
        <a href="/services/" class="link-arrow">View residential services <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div class="card-image"><span class="card-badge">Residential</span>(estate site plan)</div>
          <div class="card-body">
            <h3>Luxury Estate Site Plan</h3>
            <p>Full site documentation of a ~1-acre Nellie Gail Ranch property &mdash; main residence, 2-car garage, carport, pool, spa with equipment, gazebo, BBQ area, and driveway. Dimensioned across ~205&prime; &times; 209&prime; lot.</p>
          </div>
          <div class="card-footer">
            <span>Laguna Hills, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Residential</span>(duplex remodel)</div>
          <div class="card-body">
            <h3>Coastal Duplex Remodel</h3>
            <p>2,954 SF existing-conditions floor plan for a 2-story R-3 residential duplex receiving a kitchen and bathroom remodel. Delivered for permit submittal with code-compliant scope of work documentation.</p>
          </div>
          <div class="card-footer">
            <span>Corona Del Mar, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Residential</span>(coastal home)</div>
          <div class="card-body">
            <h3>Coastal Single-Family Home</h3>
            <p>Existing-conditions site plan and floor plan documentation for a coastal single-family residence in the Carlsbad lagoon area. Captured for renovation planning, dimensioned ready for design work.</p>
          </div>
          <div class="card-footer">
            <span>Carlsbad, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRIAL -->
  <section>
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Industrial</div>
          <h2>Warehouse, flex, distribution</h2>
        </div>
        <a href="/services/" class="link-arrow">View industrial services <span class="arrow">→</span></a>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div class="card-image"><span class="card-badge">Industrial</span>(warehouse plan)</div>
          <div class="card-body">
            <h3>Industrial Warehouse Documentation</h3>
            <p>Full existing-conditions floor plan for a multi-bay industrial property &mdash; <strong>156&prime; wide</strong> with repeating 24&prime; structural bays and <strong>15&prime;-4&Prime; clear ceiling height</strong>. Mixed warehouse + office layout documented in a single visit.</p>
          </div>
          <div class="card-footer">
            <span>Placentia, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Industrial</span>(flex space)</div>
          <div class="card-body">
            <h3>Light Industrial Flex Space</h3>
            <p>4,962 SF flex floor plan &mdash; 3,828 SF warehouse with <strong>16&prime;-6&Prime; clear height</strong>, two 12&prime;&times;12&prime; dock doors, plus 1,134 SF office and restrooms. Captured in one visit, delivered for tenant improvement scoping.</p>
          </div>
          <div class="card-footer">
            <span>Laguna Hills, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Industrial</span>(commerce center)</div>
          <div class="card-body">
            <h3>Multi-Unit Commerce Center</h3>
            <p>Floor plan documentation across multiple flex/industrial units within a single commerce center property. Per-unit dimensioned drawings delivered to support the owner&rsquo;s leasing and tenant onboarding workflow.</p>
          </div>
          <div class="card-footer">
            <span>Laguna Hills, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Have a project to scope?</h3>
          <p>Tell us what you&rsquo;re working on and we&rsquo;ll put together a custom quote within one business day.</p>
        </div>
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
