---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Projects — As-Built Company">
  <section class="hero hero-compact">
    <div class="container">
      <div class="eyebrow">Projects</div>
      <h1>Recent <span class="accent">work.</span></h1>
      <p class="lead">A selection of buildings, sites, and renovations we&rsquo;ve scanned and documented across California.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-3">
        <div class="card">
          <div class="card-image"><span class="card-badge">Commercial</span>(image placeholder)</div>
          <div class="card-body">
            <h3>500,000 SF Office Retrofit</h3>
            <p>Full as-built capture and LOD 300 Revit model for a multi-floor office renovation downtown.</p>
          </div>
          <div class="card-footer">
            <span>Los Angeles, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Residential</span>(image placeholder)</div>
          <div class="card-body">
            <h3>Historic Craftsman Home</h3>
            <p>Point cloud and dimensioned floor plans of a 1920s home for a sensitive renovation.</p>
          </div>
          <div class="card-footer">
            <span>Pasadena, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Industrial</span>(image placeholder)</div>
          <div class="card-body">
            <h3>Manufacturing Facility</h3>
            <p>Floor-to-ceiling scan of an active plant with shareable 360&deg; virtual tour for remote teams.</p>
          </div>
          <div class="card-footer">
            <span>Inland Empire, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Real Estate</span>(image placeholder)</div>
          <div class="card-body">
            <h3>Multi-Unit Property Floor Plans</h3>
            <p>Dimensioned floor plans for a 12-unit apartment building delivered in 48 hours.</p>
          </div>
          <div class="card-footer">
            <span>Long Beach, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Healthcare</span>(image placeholder)</div>
          <div class="card-body">
            <h3>Outpatient Clinic As-Builts</h3>
            <p>MEP-coordinated as-builts for a working medical facility, captured outside business hours.</p>
          </div>
          <div class="card-footer">
            <span>San Diego, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>

        <div class="card">
          <div class="card-image"><span class="card-badge">Hospitality</span>(image placeholder)</div>
          <div class="card-body">
            <h3>Boutique Hotel Renovation</h3>
            <p>Existing-conditions scan and Revit model for a full-floor guestroom remodel.</p>
          </div>
          <div class="card-footer">
            <span>Santa Monica, CA</span>
            <a href="/contact/" class="arrow-link">Discuss similar →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Have a project to scope?</h3>
          <p>Tell us what you&rsquo;re working on and we&rsquo;ll put together a custom quote.</p>
        </div>
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
