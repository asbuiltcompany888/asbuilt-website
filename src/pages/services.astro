---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Services — As-Built Company">
  <section class="hero hero-compact">
    <div class="container">
      <div class="eyebrow">Services</div>
      <h1>Capture, document, <span class="accent">deliver.</span></h1>
      <p class="lead">From a single scan to a full as-built documentation package — choose the deliverables you need, or let us scope the right combination for your project.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-3">
        <div class="icon-card">
          <div class="icon">◧</div>
          <h3>3D Laser Scanning</h3>
          <p>Survey-grade point clouds with the Leica BLK2GO for fast, mobile-mapping accuracy on sites of any size. Ideal for renovations, retrofits, and existing-conditions documentation.</p>
        </div>
        <div class="icon-card">
          <div class="icon">▤</div>
          <h3>As-Built Drawings</h3>
          <p>Floor plans, reflected ceiling plans, elevations, sections, and details — produced in AutoCAD or Revit from registered scan data.</p>
        </div>
        <div class="icon-card">
          <div class="icon">◉</div>
          <h3>360&deg; Virtual Tours</h3>
          <p>Stitched and stop-tagged walkthroughs from Insta360 captures, hosted as shareable browser tours your clients can navigate without an app.</p>
        </div>
        <div class="icon-card">
          <div class="icon">▦</div>
          <h3>BIM Modeling (Revit / Rhino)</h3>
          <p>LOD 200 to LOD 400 models built from registered scan data, ready for coordination, clash detection, or design development.</p>
        </div>
        <div class="icon-card">
          <div class="icon">⌬</div>
          <h3>Point Cloud Processing</h3>
          <p>Registration, decimation, and conversion (E57, RCS/RCP, LAS, PTS) to fit your downstream software workflow.</p>
        </div>
        <div class="icon-card">
          <div class="icon">△</div>
          <h3>Volumetric &amp; Quantity Surveys</h3>
          <p>Cut/fill calculations, stockpile volumes, and area takeoffs derived from scan data.</p>
        </div>
        <div class="icon-card">
          <div class="icon">⌂</div>
          <h3>Real Estate Floor Plans</h3>
          <p>Dimensioned 2D floor plans for listings, lease drawings, and property records &mdash; typically delivered within 48 hours.</p>
        </div>
        <div class="icon-card">
          <div class="icon">⊞</div>
          <h3>Construction Progress Capture</h3>
          <p>Recurring site scans for milestone documentation, dispute mitigation, and remote stakeholder updates.</p>
        </div>
        <div class="icon-card">
          <div class="icon">⌖</div>
          <h3>Custom Deliverables</h3>
          <p>Don&rsquo;t see exactly what you need? Tell us the goal and we&rsquo;ll scope the right combination of deliverables.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Need a custom scope?</h3>
          <p>Tell us your project goals and we&rsquo;ll put together a quote within one business day.</p>
        </div>
        <a href="/contact/" class="btn">Request a Custom Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
