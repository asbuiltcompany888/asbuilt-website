---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Areas We Serve — As-Built Company California"
  description="On-site 3D laser scanning and as-built documentation across California — Los Angeles, San Francisco Bay Area, San Diego, Sacramento, Orange County, and the Inland Empire."
>
  <section class="hero hero-compact">
    <div class="container">
      <div class="eyebrow">Areas We Serve</div>
      <h1>On-site capture across <span class="accent">California.</span></h1>
      <p class="lead">Statewide service from Los Angeles to the Bay Area, with no travel-fee surcharges on most projects. Tell us your site address and we&rsquo;ll confirm coverage and timing.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-3">
        <div class="area-card">
          <span class="region">Greater LA</span>
          <h3>Los Angeles County</h3>
          <p class="cities">Los Angeles, Pasadena, Long Beach, Glendale, Santa Monica, Burbank, Inglewood, Downey, Torrance, West Hollywood, Beverly Hills, Culver City, Manhattan Beach, Hermosa Beach.</p>
        </div>
        <div class="area-card">
          <span class="region">Orange County</span>
          <h3>Orange County</h3>
          <p class="cities">Anaheim, Santa Ana, Irvine, Huntington Beach, Newport Beach, Costa Mesa, Fullerton, Mission Viejo, Laguna Beach, Tustin, Yorba Linda, Brea.</p>
        </div>
        <div class="area-card">
          <span class="region">Inland Empire</span>
          <h3>Inland Empire</h3>
          <p class="cities">Riverside, San Bernardino, Ontario, Rancho Cucamonga, Fontana, Corona, Moreno Valley, Murrieta, Temecula, Chino, Redlands.</p>
        </div>
        <div class="area-card">
          <span class="region">San Diego</span>
          <h3>San Diego County</h3>
          <p class="cities">San Diego, Chula Vista, Oceanside, Escondido, Carlsbad, El Cajon, Vista, San Marcos, La Mesa, Encinitas.</p>
        </div>
        <div class="area-card">
          <span class="region">Bay Area</span>
          <h3>San Francisco Bay Area</h3>
          <p class="cities">San Francisco, San Jose, Oakland, Berkeley, Fremont, Palo Alto, Sunnyvale, Mountain View, Redwood City, San Mateo, Walnut Creek, Hayward.</p>
        </div>
        <div class="area-card">
          <span class="region">Central Valley</span>
          <h3>Sacramento &amp; Central Valley</h3>
          <p class="cities">Sacramento, Stockton, Modesto, Fresno, Bakersfield, Roseville, Elk Grove, Folsom, Davis, Visalia.</p>
        </div>
        <div class="area-card">
          <span class="region">Central Coast</span>
          <h3>Central &amp; Coastal California</h3>
          <p class="cities">Santa Barbara, Ventura, San Luis Obispo, Monterey, Salinas, Santa Cruz, Paso Robles, Oxnard, Camarillo.</p>
        </div>
        <div class="area-card">
          <span class="region">Statewide</span>
          <h3>Anywhere else in California</h3>
          <p class="cities">Have a site outside these regions? Most California projects are reachable within a day&rsquo;s drive. Tell us your address and we&rsquo;ll confirm coverage and travel logistics.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-surface">
    <div class="container">
      <div class="cta-strip">
        <div class="text">
          <h3>Not sure if we cover your area?</h3>
          <p>Send your project address and we&rsquo;ll confirm coverage, timing, and any travel logistics.</p>
        </div>
        <a href="/contact/" class="btn">Get a Quote <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
